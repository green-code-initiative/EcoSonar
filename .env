# =============================================================================
# EcoSonar - Local Environment Configuration
# =============================================================================
# /!\ Do NOT commit this file to version control.
#     It is listed in .gitignore for this reason.
#     To share configuration, use .env.example instead.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_ROOT_USERNAME=mongodb
MONGO_ROOT_PASSWORD=changeme

# User created by mongo-init.sh (used by the EcoSonar API)
MONGO_USERNAME=ecosonar
MONGO_PASSWORD=changeme

# -----------------------------------------------------------------------------
# PostgreSQL (used by SonarQube)
# -----------------------------------------------------------------------------
POSTGRES_USER=sonar
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sonarqube

# -----------------------------------------------------------------------------
# EcoSonar API
# -----------------------------------------------------------------------------
ECOSONAR_API_PORT=3000
ECOSONAR_ENV_CLOUD_PROVIDER=local
ECOSONAR_ENV_DB_NAME=EcoSonar
ECOSONAR_ENV_DB_TYPE=MongoDB
ECOSONAR_ENV_SONARQUBE_SERVER_URL=http://xxx.xxx.xxx.xx:9000
ECOSONAR_ENV_LOCAL_DEV_SERVER_URL=http://xxx.xxx.xxx.xx:3000

# -----------------------------------------------------------------------------
# SonarQube
# -----------------------------------------------------------------------------
SONARQUBE_PORT=9000

# SonarQube plugin build URL — must match ECOSONAR_API_PORT above
REACT_APP_BASE_URL_ECOSONAR_API=http://xxx.xxx.xxx.xx:3000
